generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Match {
  id            Int      @id @default(autoincrement())
  externalId    Int      @unique
  name          String
  homeTeamName  String
  awayTeamName  String
  startTime     DateTime
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, startTime])
}
